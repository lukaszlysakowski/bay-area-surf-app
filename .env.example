# Copy to .env and fill in. .env is gitignored.

# Mapbox access token — required for the map view.
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# WorldTides API key — OPTIONAL fallback tide source, used only when NOAA
# CO-OPS is unavailable. Read server-side by vite.config.ts and injected into
# the /api/worldtides proxy (no VITE_ prefix, so it never reaches the browser).
# Each fallback call costs 2 credits (heights + extremes). https://www.worldtides.info/
WORLDTIDES_API_KEY=
